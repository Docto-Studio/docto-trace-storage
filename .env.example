# Docto Trace Storage — Environment Variables
# ---------------------------------------------------------------------------
# Core Configuration
# ---------------------------------------------------------------------------
# DOCTO_TRACE_CREDENTIALS_PATH=credentials.json
# DOCTO_TRACE_MAX_DEPTH=unlimited
# DOCTO_TRACE_OUTPUT_DIR=output/

# ---------------------------------------------------------------------------
# AI Readiness (LLM) — LiteLLM Supported Keys
# ---------------------------------------------------------------------------
# The CLI allows '--llm-model' to generate a qualitative AI Readiness report.
# Depending on the model you specify, provide the API key here:

# OpenAI (e.g. --llm-model openai/gpt-4o-mini)
OPENAI_API_KEY=sk-...

# Anthropic (e.g. --llm-model anthropic/claude-3-haiku-20240307)
# ANTHROPIC_API_KEY=sk-ant-...

# Cohere (e.g. --llm-model cohere/command-r)
# COHERE_API_KEY=...

# Ollama / Local (e.g. --llm-model ollama/llama3)
# OLLAMA_API_BASE="http://localhost:11434"
